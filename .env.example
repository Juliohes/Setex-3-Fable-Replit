# ── Núcleo ────────────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO
JWT_SECRET=                        # generar: python -c "import secrets;print(secrets.token_urlsafe(64))"
DATABASE_URL=                      # en Replit la inyecta la herramienta PostgreSQL (Neon)
AUTO_MIGRATE=1                     # crea tablas + RLS al arrancar (modo Replit)
PLATFORM_ADMIN_EMAILS=juliohesuni@gmail.com,albertomurimarti@gmail.com

# ── Almacenamiento de ficheros ────────────────────────────────────────────
STORAGE_BACKEND=local              # local | replit  (App Storage de Replit)
STORAGE_LOCAL_DIR=.data/files

# ── Motores OCR (si faltan claves, la app funciona en modo entrada manual) ─
MISTRAL_API_KEY=
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# ── Verificación externa del CIF de contraparte ───────────────────────────
VIES_ENABLED=1
AEAT_CENSAL_ENABLED=0              # requiere certificado electrónico montado
AEAT_CERT_PATH=
AEAT_KEY_PATH=

# ── Email (stub) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=soporte@autoken.es
